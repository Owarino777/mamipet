@startuml
title MamiPet - Diagramme de cas d'utilisation du MVP

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #F8FBFF
  BorderColor #32506D
}
skinparam rectangle {
  BorderColor #32506D
}

actor "Visiteur" as Visiteur
actor "Utilisateur\nauthentifie" as Utilisateur
actor "Proprietaire" as Proprietaire
actor "Pet-sitter" as PetSitter
actor "Administrateur" as Admin
actor "Stripe Connect\ntest" as Stripe
actor "Google Maps API" as Maps
actor "Supabase Auth" as SupabaseAuth

Proprietaire --|> Utilisateur
PetSitter --|> Utilisateur
Admin --|> Utilisateur

rectangle "Systeme MamiPet - MVP applicatif" {
  package "Acces et comptes" {
    usecase "Creer un compte" as UC_CreateAccount
    usecase "Se connecter" as UC_Login
    usecase "Recuperer le compte courant" as UC_CurrentAccount
    usecase "Activer un profil\nproprietaire" as UC_ActivateOwner
    usecase "Activer un profil\npet-sitter" as UC_ActivatePetSitter
  }

  package "Decouverte publique" {
    usecase "Rechercher des\npet-sitters" as UC_Search
    usecase "Filtrer les resultats" as UC_Filter
    usecase "Consulter une fiche\npet-sitter publique" as UC_PublicProfile
    usecase "Afficher une zone\ngeographique protegee" as UC_Map
  }

  package "Proprietaire et animaux" {
    usecase "Completer le profil\nproprietaire" as UC_OwnerProfile
    usecase "Gerer les animaux" as UC_ManagePets
    usecase "Gerer le dossier\nmedical confidentiel" as UC_Medical
    usecase "Joindre des documents\nanimaux" as UC_AnimalDocs
  }

  package "Pet-sitter et qualification" {
    usecase "Completer le profil\npet-sitter" as UC_PetProfile
    usecase "Configurer l'offre\n(especes, capacites,\nlieux, formats, services)" as UC_ConfigureOffer
    usecase "Declarer des\ndisponibilites" as UC_Availability
    usecase "Deposer un document\nprofessionnel" as UC_ProfessionalDoc
    usecase "Passer un test de\nvalidation" as UC_Test
    usecase "Consulter ses badges\npublics" as UC_Badges
  }

  package "Reservation directe" {
    usecase "Creer une demande\nde reservation" as UC_CreateBooking
    usecase "Accepter une demande" as UC_AcceptBooking
    usecase "Refuser une demande" as UC_RefuseBooking
    usecase "Bloquer le creneau" as UC_BlockSlot
    usecase "Annuler une reservation" as UC_CancelBooking
    usecase "Declarer un incident" as UC_ReportIncident
    usecase "Passer la reservation\na terminee" as UC_CloseBooking
  }

  package "Paiement et contrat" {
    usecase "Payer la reservation\nen mode test" as UC_PayBooking
    usecase "Confirmer le paiement" as UC_ConfirmPayment
    usecase "Generer le contrat\nrecapitulatif" as UC_GenerateContract
    usecase "Consulter le contrat" as UC_ReadContract
  }

  package "Confiance et moderation" {
    usecase "Deposer un avis apres\nprestation terminee" as UC_Review
    usecase "Repondre a un avis" as UC_ReviewReply
    usecase "Creer un signalement" as UC_CreateReport
    usecase "Consulter ses\nsignalements" as UC_ReadReports
  }

  package "Administration" {
    usecase "Lister les profils\na valider" as UC_AdminProfiles
    usecase "Valider ou rejeter\nun document" as UC_AdminDocs
    usecase "Changer le statut de\nverification" as UC_AdminStatus
    usecase "Attribuer ou retirer\nun badge" as UC_AdminBadges
    usecase "Consulter reservations\net paiements" as UC_AdminBookings
    usecase "Traiter un signalement" as UC_AdminReports
    usecase "Conserver une trace\ndes actions sensibles" as UC_Audit
  }
}

Visiteur --> UC_Search
Visiteur --> UC_Filter
Visiteur --> UC_PublicProfile

Utilisateur --> UC_CreateAccount
Utilisateur --> UC_Login
Utilisateur --> UC_CurrentAccount
Utilisateur --> UC_ActivateOwner
Utilisateur --> UC_ActivatePetSitter

Proprietaire --> UC_OwnerProfile
Proprietaire --> UC_ManagePets
Proprietaire --> UC_Medical
Proprietaire --> UC_AnimalDocs
Proprietaire --> UC_CreateBooking
Proprietaire --> UC_PayBooking
Proprietaire --> UC_ReadContract
Proprietaire --> UC_Review
Proprietaire --> UC_CreateReport
Proprietaire --> UC_ReadReports

PetSitter --> UC_PetProfile
PetSitter --> UC_ConfigureOffer
PetSitter --> UC_Availability
PetSitter --> UC_ProfessionalDoc
PetSitter --> UC_Test
PetSitter --> UC_Badges
PetSitter --> UC_AcceptBooking
PetSitter --> UC_RefuseBooking
PetSitter --> UC_ReviewReply
PetSitter --> UC_CreateReport
PetSitter --> UC_ReadReports

Admin --> UC_AdminProfiles
Admin --> UC_AdminDocs
Admin --> UC_AdminStatus
Admin --> UC_AdminBadges
Admin --> UC_AdminBookings
Admin --> UC_AdminReports
Admin --> UC_Audit

UC_Search .> UC_Filter : <<include>>
UC_Search .> UC_Map : <<include>>
UC_CreateBooking .> UC_PublicProfile : <<include>>
UC_CreateBooking .> UC_ManagePets : <<include>>
UC_AcceptBooking .> UC_BlockSlot : <<include>>
UC_PayBooking .> UC_ConfirmPayment : <<include>>
UC_ConfirmPayment .> UC_GenerateContract : <<include>>
UC_Review .> UC_CloseBooking : <<extend>>
UC_AdminDocs .> UC_AdminBadges : <<extend>>
UC_AdminReports .> UC_Audit : <<include>>
UC_AdminDocs .> UC_Audit : <<include>>
UC_AdminStatus .> UC_Audit : <<include>>
UC_AdminBadges .> UC_Audit : <<include>>

SupabaseAuth --> UC_CreateAccount
SupabaseAuth --> UC_Login
Stripe --> UC_PayBooking
Stripe --> UC_ConfirmPayment
Maps --> UC_Map

note bottom of UC_Medical
  Les donnees medicales ne sont jamais publiques.
  Elles sont accessibles uniquement dans un contexte autorise.
end note

note right of UC_AdminBadges
  Expert est un badge public,
  pas un etat du profil pet-sitter.
end note

@enduml
